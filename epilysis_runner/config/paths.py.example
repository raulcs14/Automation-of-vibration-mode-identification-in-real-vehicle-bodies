"""
Local paths configuration — copy this file to paths.py and fill in your own paths.
paths.py is gitignored, so each user keeps their own copy.

Usage:
    cp epilysis_runner/config/paths.py.example epilysis_runner/config/paths.py
    # then edit paths.py with your local paths
"""

from pathlib import Path

# --- Epilysis executable -------------------------------------------------------
# Path to epilysis.bat (Windows) or epilysis (Linux/Mac)
EPILYSIS_EXE = Path(r"C:\path\to\BETA_CAE_Systems\ansa_vXX.X.X\epilysis.bat")

# --- Repo-relative paths (no need to change) -----------------------------------
# .dat files and BDF includes are kept in data/seat_model/TB/ansa/<analysis>/input/
# Epilysis writes results to data/seat_model/TB/ansa/<analysis>/output/
_REPO_ROOT   = Path(__file__).resolve().parents[2]
_ANSA_ROOT   = _REPO_ROOT / "data" / "seat_model" / "TB" / "ansa"

MODAL_DIR    = _ANSA_ROOT / "modal"    / "input"
STATIC_DIR   = _ANSA_ROOT / "static"   / "input"
MATRICES_DIR = _ANSA_ROOT / "matrices" / "input"

# --- DAT file names (relative to each input folder) ---------------------------
MODAL_DAT    = "000_Header_TB_modal.dat"
STATIC_DAT   = "000_Header_TB_static_reference.dat"
MATRICES_DAT = "000_Header_TB_getKM.dat"

OUTPUT_ROOT  = _ANSA_ROOT
