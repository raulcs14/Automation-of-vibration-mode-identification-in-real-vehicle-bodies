"""
Local paths configuration — copy this file to paths.py and fill in your own paths.
paths.py is gitignored, so each user keeps their own copy.

Usage:
    cp epilysis_runner/config/paths.py.example epilysis_runner/config/paths.py
    # then edit paths.py with your local paths
"""

from pathlib import Path

# --- Epilysis executable -------------------------------------------------------
# Path to epilysis.bat (Windows) or epilysis (Linux/Mac)
EPILYSIS_EXE = Path(r"C:\path\to\BETA_CAE_Systems\ansa_vXX.X.X\epilysis.bat")

# --- Repo-relative paths (no need to change) -----------------------------------
_REPO_ROOT = Path(__file__).resolve().parents[3]

# --- TB (Trimmed Body) ---------------------------------------------------------
_TB_ROOT = _REPO_ROOT / "data" / "seat_model" / "TB" / "ansa"

TB_MODAL_DIR    = _TB_ROOT / "modal"    / "input"
TB_STATIC_DIR   = _TB_ROOT / "static"   / "input"
TB_MATRICES_DIR = _TB_ROOT / "matrices" / "input"

TB_MODAL_DAT    = "000_Header_TB_modal.dat"
TB_STATIC_DAT   = "000_Header_TB_static_reference.dat"
TB_MATRICES_DAT = "000_Header_TB_getKM.dat"

TB_OUTPUT_ROOT  = _TB_ROOT

# --- BIW (Body in White) -------------------------------------------------------
_BIW_ROOT = _REPO_ROOT / "data" / "seat_model" / "BIW" / "ansa"

BIW_MODAL_DIR    = _BIW_ROOT / "modal"    / "input"
BIW_STATIC_DIR   = _BIW_ROOT / "static"   / "input"
BIW_MATRICES_DIR = _BIW_ROOT / "matrices" / "input"

BIW_MODAL_DAT    = "000_Header_BIW_modal.dat"
BIW_STATIC_DAT   = "000_Header_BIW_static_reference.dat"
BIW_MATRICES_DAT = "000_Header_BIW_getKM.dat"

BIW_OUTPUT_ROOT  = _BIW_ROOT

# --- Legacy aliases (kept for backward compatibility) --------------------------
_ANSA_ROOT   = _TB_ROOT
MODAL_DIR    = TB_MODAL_DIR
STATIC_DIR   = TB_STATIC_DIR
MATRICES_DIR = TB_MATRICES_DIR
MODAL_DAT    = TB_MODAL_DAT
STATIC_DAT   = TB_STATIC_DAT
MATRICES_DAT = TB_MATRICES_DAT
OUTPUT_ROOT  = TB_OUTPUT_ROOT
